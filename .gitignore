```gitignore
# Compiled Python files
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/
.env
.env.local
*.env.*

# IDE and editor files
.vscode/
.idea/
*.swp
*.swo
*.tmp

# Logs
*.log

# Build artifacts
build/
dist/
target/

# Coverage reports
.coverage
coverage/
htmlcov/

# Python cache
.mypy_cache/
.pytest_cache/
```